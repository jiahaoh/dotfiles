# Aliases
alias ea="cursor ~/.aliases"

# Easier navigation: .., ..., ...., ....., ~ and -
alias ~="cd ~"
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."
alias .....="cd ../../../.."

# list shortcuts
alias l="eza --icons --long" # all files colorized in long format
alias la="eza --icons --long --all" # all files colorized in long format, excluding . and ..
alias lsd="eza --icons --long --only-dirs" # only directories
alias ls="eza --icons" # always use color output and icons for `ls`

# grep
alias grep='grep --color=auto' # always enable colored `grep` output
alias fgrep='fgrep --color=auto' # always enable colored `fgrep` output
alias egrep='egrep --color=auto' # always enable colored `egrep` output

# One letter shortcuts
alias c="clear"
alias v="nvim"
alias t="task"
alias x="tmux"

# navigation shortcuts
alias gl="cd ~/Downloads"
alias gd="cd ~/Desktop"
alias gg="cd ~/Desktop/GitHub"

# Claude Code
alias ccx="claude --allow-dangerously-skip-permissions"
ws() { claude -p "search the web for: $*, return top 5 results" --allowedTools "WebSearch,WebFetch" --model claude-haiku-4-5-20251001; }

# tmux
alias mux="tmuxinator start"

# SSH
alias ssh_broad_01='ssh jiahao@login01.broadinstitute.org'
alias ssh_29c='ssh jiahao@gp099-29c'

# Jupyter Notebook
alias jn="jupyter notebook"

# Show the $PATH
alias path='echo -e ${PATH//:/\\n}'

# Other
alias weather='curl wttr.in'


# macOS-only aliases
if [[ "$(uname)" == "Darwin" ]]; then
    # Open current folder in the finder
    alias opf='open -a Finder ./'

    # Open with Apps
    alias opt='open -a TextEdit'
    alias opc='open -a Google\ Chrome'
    google() { open -a "Google Chrome" "https://www.google.com/search?q=$(python3 -c "import urllib.parse; print(urllib.parse.quote('$*'))")"; }

fi

